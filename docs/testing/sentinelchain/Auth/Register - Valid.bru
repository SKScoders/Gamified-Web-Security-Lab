meta {
  name: Register - Valid
  type: http
  seq: 1
}

post {
  url: {{base_url}}/auth/register
  body: json
  {
    "email": "test-{{timestamp}}@example.com",
    "password": "SecurePass123!",
    "displayName": "Test User"
  }
}

expect {
  res.status: 201
  res.body.accessToken: exists
  res.body.refreshToken: exists
  res.body.user.email: exists
}
